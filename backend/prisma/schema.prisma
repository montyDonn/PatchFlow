generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username            String           @unique
  passwordHash        String
  salt                String
  role                String           @default("DEVELOPER")
  name                String
  designation         String?
  previousDesignation String?
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  createdBy           String?          @db.Uuid
  auditLogs           AuditLog[]       @relation("AuditChangedBy")
  targetedLogs        AuditLog[]       @relation("AuditTargetUser")
  notifications       Notification[]
  sessions            Session[]
  approvedTasks       Task[]           @relation("TaskApprover")
  assignedTasks       Task[]           @relation("TaskAssignee")
  authoredTasks       Task[]           @relation("TaskAuthor")
  deployedTasks       Task[]           @relation("TaskDeployer")
  verifiedTasks       Task[]           @relation("TaskVerifier")
  clientTasks         Task[]           @relation("TaskClient")
  managedTasks        Task[]           @relation("TaskManagers")
  developerTasks      Task[]           @relation("TaskDevelopers")
  verifierTasks       Task[]           @relation("TaskVerifiers")
  attachments         TaskAttachment[]
  taskComments        TaskComment[]
  statusHistories     StatusHistory[]  @relation("StatusChangedBy")
  creator             User?            @relation("UserCreator", fields: [createdBy], references: [userId])
  createdUsers        User[]           @relation("UserCreator")
  managerAssignments  UserManager[]    @relation("ManagerRelation")
  userAssignments     UserManager[]    @relation("UserRelation")
  modules             Module[]         @relation("UserModules")
}

model Session {
  sessionId String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  user      User     @relation(fields: [userId], references: [userId])
}

model Project {
  projectId   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectName String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  modules     Module[]
}

model Module {
  moduleId    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String       @db.Uuid
  moduleName  String       @unique
  description String?
  isActive    Boolean      @default(true)
  project     Project      @relation(fields: [projectId], references: [projectId])
  tasks       Task[]
  users       User[]       @relation("UserModules")
}

model UserManager {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid
  managerId  String   @db.Uuid
  assignedAt DateTime @default(now())
  manager    User     @relation("ManagerRelation", fields: [managerId], references: [userId])
  user       User     @relation("UserRelation", fields: [userId], references: [userId])
}

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id               String           @id @default(uuid())
  clientRequestId  Int              @default(0)
  title            String
  description      String
  status           String           @default("STEP_1_DRAFT")
  authorId         String           @db.Uuid
  assigneeId       String?          @db.Uuid
  approverId       String?          @db.Uuid
  deployerId       String?          @db.Uuid
  verifierId       String?          @db.Uuid
  teamId           String?
  moduleId         String?          @db.Uuid
  assignedAt       DateTime?
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lifecycleStatus  Int              @default(0)
  clientId         String?          @db.Uuid
  dateGiven        DateTime?
  dateStarted      DateTime?
  dateEnded        DateTime?
  client           User?            @relation("TaskClient", fields: [clientId], references: [userId])
  managers         User[]           @relation("TaskManagers")
  developers       User[]           @relation("TaskDevelopers")
  verifiers        User[]           @relation("TaskVerifiers")
  auditLogs        AuditLog[]
  statusHistory    StatusHistory[]
  approver         User?            @relation("TaskApprover", fields: [approverId], references: [userId])
  assignee         User?            @relation("TaskAssignee", fields: [assigneeId], references: [userId])
  author           User             @relation("TaskAuthor", fields: [authorId], references: [userId])
  deployer         User?            @relation("TaskDeployer", fields: [deployerId], references: [userId])
  module           Module?          @relation(fields: [moduleId], references: [moduleId])
  team             Team?            @relation(fields: [teamId], references: [id])
  verifier         User?            @relation("TaskVerifier", fields: [verifierId], references: [userId])
  attachments      TaskAttachment[]
  comments         TaskComment[]
}

model TaskComment {
  id         String   @id @default(uuid())
  taskId     String
  userId     String   @db.Uuid
  content    String
  authorName String?
  authorRole String?
  files      Json?
  createdAt  DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id])
  user       User     @relation(fields: [userId], references: [userId])
}

model TaskAttachment {
  id         String   @id @default(uuid())
  taskId     String
  uploaderId String   @db.Uuid
  fileUrl    String
  fileName   String
  fileType   String
  size       Int
  createdAt  DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id])
  uploader   User     @relation(fields: [uploaderId], references: [userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [userId])
}

model AuditLog {
  logId        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changedBy    String?  @db.Uuid
  targetUserId String?  @db.Uuid
  fieldChanged String
  oldValue     String?
  newValue     String?
  changedAt    DateTime @default(now())
  reason       String
  taskId       String?
  actor        User?    @relation("AuditChangedBy", fields: [changedBy], references: [userId])
  targetUser   User?    @relation("AuditTargetUser", fields: [targetUserId], references: [userId])
  task         Task?    @relation(fields: [taskId], references: [id])
}

model StatusHistory {
  id                String   @id @default(uuid())
  taskId            String
  previousStatus    String
  newStatus         String
  changedById       String?  @db.Uuid
  changedByName     String?
  changedByUsername String?
  changedByRole     String?
  reason            String?
  createdAt         DateTime @default(now())
  task              Task     @relation(fields: [taskId], references: [id])
  user              User?    @relation("StatusChangedBy", fields: [changedById], references: [userId])
}

enum task_status {
  OPEN
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  PENDING_DEPLOYMENT
  DEPLOYED
  PENDING_VERIFICATION
  VERIFIED
  CLOSED
  REJECTED
}

enum user_role {
  SUPER_ADMIN
  CLIENT
  ADMIN
  MANAGER
  DEVELOPER
  VERIFIER
}
